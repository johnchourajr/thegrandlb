    "@react-email/render": "^2.0.5",
    "@react-email/tailwind": "^2.0.7",
    "@types/express": "^5.0.6",
    "@types/node": "25.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "10.2.0",
    "eslint-config-next": "16.2.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-email": "^5.2.10",
