    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "next": "^16.2.3",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.4.1",
    "resend": "^6.10.0",
